# ============================================================
# OpenCode Platform — Variables de Entorno LOCAL
# ============================================================

# ── Base de datos PostgreSQL (LOCAL) ─────────────────────
DATABASE_URL=postgres://postgres:password123@localhost:5432/opencode?sslmode=disable

# ── Desglose de credenciales ────
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=password123
PGDATABASE=opencode

# ── Entorno ────────────────────────────────────────────────
NODE_ENV=development

# ── Puerto de la aplicación ───────────────────────────────
PORT=4096

# ── OpenCode: puerto base para instancias por usuario ─────
OPENCODE_BASE_PORT=5100

# ── Directorios ───────────────────────────────────────────
WORKSPACE_ROOT=/workspace
CONFIG_ROOT=/home/opencode/.config/opencode/users
DATA_ROOT=/home/opencode/.local/share/opencode/users

# ── Proveedores de IA (opcional) ───────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
