# ============================================================
# OpenCode Platform — Variables de Entorno para EasyPanel
# NUNCA subas este archivo a Git con valores reales
# ============================================================

# ── Base de datos PostgreSQL (EasyPanel) ─────────────────────
# URL interna (usar dentro de EasyPanel entre servicios):
# Formato: postgres://usuario:contraseña@host:puerto/base_datos?sslmode=disable
DATABASE_URL=postgres://postgres:CHANGE_ME@opencode-db:5432/opencode?sslmode=disable

# ── Desglose de credenciales (alternativa a DATABASE_URL) ────
PGHOST=opencode-db
PGPORT=5432
PGUSER=postgres
PGPASSWORD=CHANGE_ME
PGDATABASE=opencode

# ── Entorno ────────────────────────────────────────────────────
NODE_ENV=production

# ── Puerto de la aplicación ───────────────────────────────────
PORT=4096

# ── OpenCode: puerto base para instancias por usuario ─────────
OPENCODE_BASE_PORT=5100

# ── Directorios ───────────────────────────────────────────────
WORKSPACE_ROOT=/workspace
CONFIG_ROOT=/home/opencode/.config/opencode/users
DATA_ROOT=/home/opencode/.local/share/opencode/users

# ── Proveedores de IA (configura al menos uno) ───────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
